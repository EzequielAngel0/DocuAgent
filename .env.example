# Variables de entorno de DocuAgent — PLANTILLA
# Copiar a .env (local), .env.staging o .env.prod y rellenar valores reales.
# NUNCA commitear un .env con secretos. Solo este .env.example va a git.

# ============================================================
# Entorno y observabilidad
# ============================================================
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                 # true en prod (logs JSON para agregadores)

# ============================================================
# API
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
NEXT_PUBLIC_APP_NAME=DocuAgent
# Orígenes permitidos para CORS (coma-separados). OBLIGATORIO en producción.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Hosts permitidos (TrustedHostMiddleware). Vacío = sin restricción (solo dev).
ALLOWED_HOSTS=

# ============================================================
# Base de datos PostgreSQL
# ============================================================
DB_USER=docuagent_app
DB_PASSWORD=CAMBIAR_POR_GENERADO
DB_NAME=docuagent
DB_HOST=postgres
DB_PORT=5432

# ============================================================
# Qdrant (base vectorial)
# ============================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=CAMBIAR_POR_GENERADO
QDRANT_COLLECTION=documents
QDRANT_VECTOR_SIZE=1024        # dims de Cohere embed-multilingual-v3.0

# ============================================================
# Cohere (embeddings + reranking)
# ============================================================
COHERE_API_KEY=CAMBIAR
COHERE_EMBED_MODEL=embed-multilingual-v3.0
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# ============================================================
# LLM — proveedor activo + cadena de fallback
# ============================================================
LLM_PROVIDER=openai            # openai | gemini | anthropic | ollama
LLM_MODEL=gpt-4o-mini          # modelo del proveedor ACTIVO
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_FALLBACK_CHAIN=openai,gemini,anthropic,ollama

# Claves + modelos por proveedor (modelo usado cuando actúa de respaldo)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ============================================================
# LangSmith (observabilidad de cadenas)
# ============================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=docuagent

# ============================================================
# RAG (recuperación) y chunking (ingesta)
# ============================================================
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
CONFIDENCE_THRESHOLD=0.3
CHUNK_MIN_SIZE=200
CHUNK_MAX_SIZE=1500
CHUNK_OVERLAP=100

# ============================================================
# Autenticación (panel admin)
# ============================================================
JWT_SECRET_KEY=CAMBIAR_POR_GENERADO_64_CHARS
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
JWT_ISSUER=docuagent
JWT_AUDIENCE=docuagent-admin

# Rate limiting de endpoints sensibles (formato slowapi)
RATE_LIMIT_LOGIN=5/15minute
RATE_LIMIT_2FA=10/15minute
# Rate limit del WebSocket de chat (mensajes/min por IP)
RATE_LIMIT_CHAT_PER_MIN=20
# Dominio de la cookie de sesión. Vacío = host-only (localhost en dev).
# En prod/staging usar el dominio padre para compartir subdominios:
# COOKIE_DOMAIN=.tu-dominio.dev
COOKIE_DOMAIN=

# Administrador semilla (se crea/sincroniza al arrancar)
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=CAMBIAR
ADMIN_TOTP_SECRET=CAMBIAR_POR_BASE32        # generar con pyotp.random_base32()

# Cloudflare Turnstile (anti-bot en login)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=             # mismo valor que TURNSTILE_SITE_KEY

# ============================================================
# Frontend (NEXT_PUBLIC_* se inlinean en build-time)
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/chat/ws

# ============================================================
# Cloudflare Tunnel (solo staging/develop con `ops` up)
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================
# Almacenamiento de uploads
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
