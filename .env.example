# Variables de entorno para DocuAgent
# Copiar a .env y rellenar los valores reales
# NUNCA commitear el .env con valores reales

# ============================================================
# Base de datos PostgreSQL
# ============================================================
DB_USER=docuagent_app
DB_PASSWORD=CAMBIAR_POR_GENERADO
DB_NAME=docuagent
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ============================================================
# Qdrant (base vectorial)
# ============================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=CAMBIAR_POR_GENERADO
QDRANT_COLLECTION=documents

# ============================================================
# Cohere (embeddings + reranking)
# ============================================================
COHERE_API_KEY=CAMBIAR
COHERE_EMBED_MODEL=embed-multilingual-v3.0
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# ============================================================
# LLM (proveedor activo)
# ============================================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# Solo llenar la del proveedor activo
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ============================================================
# LangSmith (observabilidad)
# ============================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=CAMBIAR
LANGCHAIN_PROJECT=docuagent

# ============================================================
# RAG (parametros de busqueda)
# ============================================================
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
CONFIDENCE_THRESHOLD=0.3

# ============================================================
# API
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ENVIRONMENT=development

# ============================================================
# Autenticación (admin panel)
# ============================================================
JWT_SECRET_KEY=CAMBIAR_POR_GENERADO_64_CHARS
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Cloudflare Turnstile (anti-bot en login)
TURNSTILE_SITE_KEY=0x4AAAAAAXXXXXXXXXXXXXXX
TURNSTILE_SECRET_KEY=0x4AAAAAAXXXXXXXXXXXXXXX

# ============================================================
# Frontend
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/chat/ws
NEXT_PUBLIC_APP_NAME=DocuAgent

# ============================================================
# Cloudflare Tunnel (solo develop/staging)
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================
# Storage
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
