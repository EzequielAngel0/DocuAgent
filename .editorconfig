# EditorConfig - https://editorconfig.org
# Estilo base del repo DocuAgent (lo respeta la extension EditorConfig)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 100

[*.{ps1,psm1}]
indent_size = 4

[*.sh]
indent_size = 2

# Markdown: no recortar espacios finales (preservan saltos de linea forzados)
[*.md]
trim_trailing_whitespace = false
